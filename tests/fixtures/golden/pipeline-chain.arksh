# golden: sort → take → count
list(3, 1, 4, 1, 5, 9, 2, 6) |> sort(value asc) |> take(3) |> count() -> print()

# golden: where (equality) and print match
list(1, 2, 3, 4, 5) |> where([:it | it == number(3)]) |> each([:it | it -> print()])

# golden: map + each to transform and print
list(1, 2, 3) |> map([:it | it + number(10)]) |> each([:it | it -> print()])
