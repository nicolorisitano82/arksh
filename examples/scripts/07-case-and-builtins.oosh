# oosh example 07
# Case shell-style e built-in di scripting avanzato introdotti in E1-S4.

until false
do
text("until-once") -> print()
break
done

case text("demo.txt") in *.md) text("markdown") -> print() ;; *.txt) text("text-file") -> print() ;; *) text("other") -> print() ;; esac

eval "text(\"eval-ok\") -> print()"

trap "text(\"exit-trap\") -> print()" EXIT
text("script-end") -> print()
